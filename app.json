{
  "expo": {
    "name": "UNROT",
    "slug": "derot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.derot.app",
      "entitlements": {
        "com.apple.developer.family-controls": true,
        "com.apple.security.application-groups": ["group.io.derot.screentime"]
      },
      "infoPlist": {
        "CFBundleDisplayName": "UNROT",
        "NSUserNotificationsUsageDescription": "UNROT sends trial reminders and nudges when temptation is highest."
      }
    },
    "android": {
      "label": "UNROT",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      [
        "react-native-device-activity",
        {
          "appleTeamId": "VD7D5CUTRG",
          "appGroup": "group.io.derot.screentime"
        }
      ],
      "expo-notifications"
    ]
  }
}
