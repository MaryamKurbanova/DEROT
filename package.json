{
  "name": "derot",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "prestart": "node scripts/check-deps.mjs",
    "preandroid": "node scripts/check-deps.mjs",
    "preios": "node scripts/check-deps.mjs",
    "preweb": "node scripts/check-deps.mjs",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "expo start --dev-client",
    "prebuild:ios": "expo prebuild --platform ios",
    "build:ios:dev": "eas build --profile development --platform ios",
    "build:ios": "eas build --profile production --platform ios",
    "web": "expo start --web",
    "fix:npx-cache": "node scripts/clear-npx-cache.mjs",
    "typecheck": "tsc --noEmit",
    "gen:breath-sounds": "node scripts/generate-breath-wavs.mjs",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/nunito": "^0.2.3",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo-google-fonts/roboto-mono": "^0.2.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "derot-device-activity-chart": "file:./modules/derot-device-activity-chart",
    "expo": "~54.0.0",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-device-activity": "^0.6.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "simple-icons": "^13.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "patch-package": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true
}
